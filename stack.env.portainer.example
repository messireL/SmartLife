SMARTLIFE_PROVIDER=demo
SMARTLIFE_TUYA_BASE_URL=https://openapi.tuyaeu.com
SMARTLIFE_SYNC_INTERVAL_SECONDS=60
SMARTLIFE_BACKGROUND_SYNC_ENABLED=yes
SMARTLIFE_SYNC_ON_STARTUP=yes
